# Supabase PostgreSQL ortamı
#
# Supabase Dashboard > Project Settings > Database bölümünden connection string alın.
# Şifre içinde özel karakter varsa URL encode edilmelidir.
#
# Direct connection örneği:
# DATABASE_URL="postgresql://postgres:SUPABASE_DB_PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres?schema=public"
#
# Transaction pooler örneği:
# DATABASE_URL="postgresql://postgres.PROJECT_REF:SUPABASE_DB_PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?schema=public"

DATABASE_URL="postgresql://postgres:SUPABASE_DB_PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres?schema=public"

# İlk admin kullanıcısı seed sırasında oluşturulur.
ADMIN_EMAIL="admin@dtkubracolak.com"
ADMIN_PASSWORD="12345678"

# Production için güçlü ve rastgele 32+ karakterlik değer kullan.
ADMIN_SESSION_SECRET="replace-with-production-secret-32-chars"
