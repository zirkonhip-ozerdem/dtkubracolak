# Lokal PostgreSQL / DBeaver geliştirme ortamı
#
# DBeaver'da örnek database:
#   Host: localhost
#   Port: 5432
#   Database: dtkubracolak
#   Username: postgres
#   Password: kendi lokal PostgreSQL şifren
#
# Eğer kullanıcı veya şifre farklıysa URL içinde değiştir.

DATABASE_URL="postgresql://postgres:LOCAL_POSTGRES_PASSWORD@localhost:5432/dtkubracolak?schema=public"

# İlk admin kullanıcısı seed sırasında oluşturulur.
ADMIN_EMAIL="admin@dtkubracolak.com"
ADMIN_PASSWORD="12345678"

# Lokal için de 32+ karakterlik rastgele bir değer kullan.
ADMIN_SESSION_SECRET="local-dev-change-this-secret-32-chars"
